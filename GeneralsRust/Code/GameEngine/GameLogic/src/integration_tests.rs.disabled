        test_experience_and_veterancy();
        test_weapon_and_damage_system();
        test_ai_pathfinding_integration();
        test_scripting_system();
        test_performance_benchmark();
        test_memory_management();
        test_concurrent_access();
        test_game_state_consistency();

        let elapsed = start_time.elapsed();
        log::info!(
            "🎉 All integration tests completed successfully in {:.2}s",
            elapsed.as_secs_f64()
        );
        log::info!("✅ GameLogic system is ready for production!");
    }

    // ============================================================================
    // WEEK 7 INTEGRATION TESTS: Ballistics → Physics → Armor → Projectile
    // ============================================================================
    // Tests verify end-to-end interactions between weapon systems

    #[test]
    fn test_ballistics_physics_integration() {
        // Verify ballistic trajectory calculations integrate with physics engine
        use crate::physics::{PhysicsState, PhysicsType};
        use crate::weapon::ballistics::BallisticsCalculator;

        let start = [0.0, 0.0, 0.0];
        let target = [100.0, 0.0, 0.0];
        let velocity = 100.0;
        let gravity = 32.0;

        // Phase 1: Calculate ballistic trajectory
        let trajectory =
            BallisticsCalculator::calculate_trajectory(&start, &target, velocity, gravity)
                .expect("Trajectory calculation failed");

        assert!(
            trajectory.flight_time > 0.0,
            "Flight time should be positive"
        );
        assert!(
            trajectory.range >= 99.0 && trajectory.range <= 101.0,
            "Range should match target distance"
        );
        assert!(
            trajectory.max_height >= 0.0,
            "Max height should be non-negative"
        );

        // Phase 2: Verify physics can use calculated trajectory
        let mut physics_state = PhysicsState::new();
        physics_state.physics_type = PhysicsType::Projectile;
        physics_state.velocity = [
            trajectory.initial_velocity[0],
            trajectory.initial_velocity[1],
            trajectory.initial_velocity[2],
        ];
        physics_state.position = start;

        // Verify physics state accepts ballistic parameters
        assert_eq!(physics_state.physics_type, PhysicsType::Projectile);
        assert!(
            physics_state.velocity[0] > 0.0
                || physics_state.velocity[1] > 0.0
                || physics_state.velocity[2] > 0.0
        );

        log::info!("✅ Ballistics→Physics integration verified");
    }

    #[test]
    fn test_ballistics_with_drag_physics_simulation() {
        // Verify drag physics affects ballistic calculations
        use crate::weapon::ballistics::BallisticsCalculator;

        let start = [0.0, 0.0, 0.0];
        let target = [150.0, 0.0, 0.0];
        let velocity = 120.0;
        let gravity = 32.0;

        // Calculate trajectory without drag
        let trajectory_no_drag =
            BallisticsCalculator::calculate_trajectory(&start, &target, velocity, gravity)
                .expect("Trajectory calculation failed");

        // Calculate trajectory with drag
        let trajectory_with_drag = BallisticsCalculator::calculate_trajectory_with_drag(
            &start, &target, velocity, gravity, 0.1, // drag_coefficient
            1.0, // projectile_mass
        )
        .expect("Trajectory with drag failed");

        // Drag should reduce range or increase time
        assert!(
            trajectory_with_drag.flight_time >= trajectory_no_drag.flight_time,
            "Drag should increase flight time or keep it same"
        );

        log::info!("✅ Ballistics with drag physics verified");
    }

    #[test]
    fn test_ballistics_wind_effects_physics() {
        // Verify wind effects integrate with trajectory physics
        use crate::common::coord::Coord3D;
        use crate::weapon::ballistics::BallisticsCalculator;

        let start = [0.0, 0.0, 0.0];
        let target = [100.0, 50.0, 0.0];
        let velocity = 100.0;
        let gravity = 32.0;
        let wind = Coord3D::new(10.0, 0.0, 0.0); // Lateral wind
        let altitude_factor = 1.0;

        // Calculate trajectory with wind
        let trajectory_with_wind = BallisticsCalculator::calculate_trajectory_with_wind(
            &start,
            &target,
            velocity,
            gravity,
            &wind,
            altitude_factor,
        )
        .expect("Trajectory with wind failed");

        assert!(
            trajectory_with_wind.range > 0.0,
            "Wind-affected trajectory should have range"
        );
        assert!(
            trajectory_with_wind.flight_time > 0.0,
            "Wind-affected trajectory should have flight time"
        );

        log::info!("✅ Ballistics wind effects physics verified");
    }

    #[test]
    fn test_target_interception_confidence() {
        // Verify target interception calculations produce valid confidence factors
        use crate::common::coord::Coord3D;
        use crate::weapon::ballistics::BallisticsCalculator;

        let start = Coord3D::new(0.0, 0.0, 0.0);
        let target_pos = Coord3D::new(100.0, 0.0, 0.0);
        let target_velocity = Coord3D::new(10.0, 0.0, 0.0);
        let projectile_velocity = 100.0;
        let gravity = 32.0;

        // Calculate interception
        let intercept = BallisticsCalculator::predict_target_intercept(
            &start,
            &target_pos,
            &target_velocity,
            projectile_velocity,
            gravity,
        );

        if let Some(result) = intercept {
            assert!(
                result.intercept_time >= 0.0,
                "Intercept time should be non-negative"
            );
            assert!(
                result.confidence >= 0.0 && result.confidence <= 1.0,
                "Confidence should be between 0 and 1, got: {}",
                result.confidence
            );

            // Confidence should be high for close, slow targets
            assert!(
                result.confidence > 0.5,
                "Confidence for close target should be substantial"
            );
        }

        log::info!("✅ Target interception confidence verified");
    }

    #[test]
    fn test_physics_collision_armor_integration() {
        // Verify physics collision detection integrates with armor system
        use crate::physics::{CollisionResponse, PhysicsState, PhysicsType};
        use crate::weapon::armor_system::{ArmorDamageMatrix, ArmorType, DamageType};

        // Phase 1: Set up physics state with collision
        let mut physics_state = PhysicsState::new();
        physics_state.physics_type = PhysicsType::Projectile;
        physics_state.collision_response = CollisionResponse::Destroy;
        physics_state.position = [0.0, 0.0, 0.0];
        physics_state.velocity = [50.0, 0.0, -30.0];

        // Phase 2: Verify collision response type is set correctly
        assert_eq!(physics_state.collision_response, CollisionResponse::Destroy);

        // Phase 3: Initialize armor system for damage calculation
        let armor_matrix = ArmorDamageMatrix::new();

        // Verify different armor types can be looked up
        let human_crush_mult = armor_matrix.get_multiplier(ArmorType::Human, DamageType::Crush);
        let tank_small_arms_mult =
            armor_matrix.get_multiplier(ArmorType::Tank, DamageType::SmallArms);

        assert!(
            human_crush_mult > 1.0,
            "Infantry should be vulnerable to crush damage"
        );
        assert!(
            tank_small_arms_mult < 1.0,
            "Tanks should resist small arms fire"
        );

        log::info!("✅ Physics collision→Armor integration verified");
    }

    #[test]
    fn test_damage_calculation_with_armor_types() {
        // Verify armor matrix correctly modifies damage for all armor types
        use crate::weapon::armor_system::{ArmorDamageMatrix, ArmorType, DamageType};

        let armor_matrix = ArmorDamageMatrix::new();

        // Test Human armor vulnerabilities
        assert_eq!(
            armor_matrix.get_multiplier(ArmorType::Human, DamageType::Crush),
            2.0
        );
        assert_eq!(
            armor_matrix.get_multiplier(ArmorType::Human, DamageType::Sniper),
            2.0
        );
        assert_eq!(
            armor_matrix.get_multiplier(ArmorType::Human, DamageType::Flame),
            1.5
        );

        // Test Tank armor resistances
        assert_eq!(
            armor_matrix.get_multiplier(ArmorType::Tank, DamageType::SmallArms),
            0.25
        );
        assert!(armor_matrix.get_multiplier(ArmorType::Tank, DamageType::Gattling) <= 0.25);

        // Test Aircraft armor vulnerabilities to AA weapons
        let aa_damage =
            armor_matrix.get_multiplier(ArmorType::Aircraft, DamageType::GunEmplacement);
        assert!(
            aa_damage >= 1.0,
            "Aircraft should be vulnerable to AA weapons"
        );

        // Test Structure armor vulnerabilities to orbital weapons
        let beam_damage =
            armor_matrix.get_multiplier(ArmorType::Structure, DamageType::ParticleBeam);
        assert!(
            beam_damage > 1.5,
            "Structures should be very vulnerable to particle beams"
        );

        log::info!("✅ Armor type damage calculations verified");
    }

    #[test]
    fn test_projectile_lifecycle_integration() {
        // Verify complete projectile lifecycle: creation→physics→collision→damage
        use crate::common::coord::Coord3D;
        use crate::weapon::projectile::Projectile;
        use std::sync::Arc;

        let weapon_template = Arc::new(crate::weapon::weapon::WeaponTemplate::new(
            "TestWeapon".to_string(),
        ));
        let trajectory = crate::weapon::ballistics::BallisticsTrajectory {
            initial_velocity: Coord3D::new(100.0, 0.0, 10.0),
            launch_angle: 0.1,
            flight_time: 1.0,
            max_height: 5.0,
            range: 100.0,
            trajectory_points: vec![],
        };

        // Phase 1: Create projectile
        let mut projectile = Projectile::new(
            1,
            crate::weapon::projectile::ProjectileType::Ballistic,
            weapon_template,
            2,
            Some(3),
            Coord3D::new(0.0, 0.0, 0.0),
            trajectory,
            crate::weapon::weapon::WeaponBonus::new(),
                    None,
                    INVALID_OBJECT_ID,
                    None,
        );

        // Phase 2: Verify projectile state
        assert_eq!(projectile.projectile_id, 1);
        assert!(projectile.time_alive >= 0.0);

        // Phase 3: Update projectile (advance time)
        projectile.time_alive += 0.1;
        assert!(projectile.time_alive > 0.0);

        // Phase 4: Verify projectile can be used in physics system
        assert!(projectile.position[0] >= 0.0 || projectile.position[0] < 0.0); // Valid position

        log::info!("✅ Projectile lifecycle integration verified");
    }

    #[test]
    fn test_multiple_projectile_physics_collision() {
        // Verify multiple projectiles can coexist and interact with physics
        use crate::common::coord::Coord3D;
        use crate::weapon::projectile::Projectile;
        use std::sync::Arc;

        let weapon_template = Arc::new(crate::weapon::weapon::WeaponTemplate::new(
            "TestWeapon".to_string(),
        ));
        let base_trajectory = crate::weapon::ballistics::BallisticsTrajectory {
            initial_velocity: Coord3D::new(100.0, 0.0, 10.0),
            launch_angle: 0.1,
            flight_time: 1.0,
            max_height: 5.0,
            range: 100.0,
            trajectory_points: vec![],
        };

        // Create multiple projectiles with different starting positions
        let mut projectiles = Vec::new();
        for i in 0..3 {
            let offset_pos = Coord3D::new(i as f32 * 10.0, 0.0, 0.0);
            let projectile = Projectile::new(
                i,
                crate::weapon::projectile::ProjectileType::Ballistic,
                weapon_template.clone(),
                2,
                Some(3),
                offset_pos,
                base_trajectory.clone(),
                crate::weapon::weapon::WeaponBonus::new(),
                    None,
                    INVALID_OBJECT_ID,
                    None,
            );
            projectiles.push(projectile);
        }

        // Verify all projectiles are distinct
        assert_eq!(projectiles.len(), 3);
        assert_eq!(projectiles[0].projectile_id, 0);
        assert_eq!(projectiles[1].projectile_id, 1);
        assert_eq!(projectiles[2].projectile_id, 2);

        // Verify each has unique position
        assert_eq!(projectiles[0].position[0], 0.0);
        assert_eq!(projectiles[1].position[0], 10.0);
        assert_eq!(projectiles[2].position[0], 20.0);

        log::info!("✅ Multiple projectile physics verified");
    }

    #[test]
    fn test_weapon_firing_ballistics_integration() {
        // Verify complete weapon firing chain from template to trajectory
        initialize_weapon_store().unwrap();

        // Create weapon template with ballistic properties
        let mut weapon_template =
            crate::weapon::weapon::WeaponTemplate::new("IntegrationTestWeapon".to_string());
        weapon_template.primary_damage = 50.0;
        weapon_template.attack_range = 200.0;
        weapon_template.muzzle_velocity = 100.0;

        let template_arc =
            with_weapon_store_mut(|store| store.add_weapon_template(weapon_template.clone()))
                .unwrap();

        // Verify weapon was stored
        let stored_weapon =
            with_weapon_store(|store| store.find_weapon_template("IntegrationTestWeapon")).unwrap();
        assert!(
            stored_weapon.is_some(),
            "Weapon should be findable in store"
        );

        // Verify template properties are accessible
        assert_eq!(template_arc.primary_damage, 50.0);
        assert_eq!(template_arc.attack_range, 200.0);

        log::info!("✅ Weapon firing ballistics integration verified");
    }

    #[test]
    fn test_physics_gravity_drag_integration() {
        // Verify gravity and drag constants are properly integrated
        use crate::physics::{PhysicsState, PhysicsType};

        const GRAVITY: f32 = 32.0;
        const AIR_RESISTANCE: f32 = 0.98;

        let mut physics_state = PhysicsState::new();
        physics_state.physics_type = PhysicsType::Projectile;
        physics_state.position = [0.0, 0.0, 100.0];
        physics_state.velocity = [100.0, 0.0, 0.0];

        // Verify physics state accepts gravity-affected movement
        // After one frame with gravity, Z velocity should decrease
        let initial_z_vel = physics_state.velocity[2];

        // Simulate gravity effect (Z velocity becomes more negative)
        physics_state.velocity[2] -= GRAVITY * (1.0 / 30.0); // 30 FPS frame

        assert!(
            physics_state.velocity[2] < initial_z_vel,
            "Gravity should decrease Z velocity"
        );

        // Simulate air resistance (velocity magnitude decreases)
        let initial_vel_mag = (physics_state.velocity[0].powi(2)
            + physics_state.velocity[1].powi(2)
            + physics_state.velocity[2].powi(2))
        .sqrt();

        physics_state.velocity[0] *= AIR_RESISTANCE;
        physics_state.velocity[1] *= AIR_RESISTANCE;
        physics_state.velocity[2] *= AIR_RESISTANCE;

        let final_vel_mag = (physics_state.velocity[0].powi(2)
            + physics_state.velocity[1].powi(2)
            + physics_state.velocity[2].powi(2))
        .sqrt();

        assert!(
            final_vel_mag < initial_vel_mag,
            "Air resistance should reduce velocity magnitude"
        );

        log::info!("✅ Physics gravity and drag integration verified");
    }

    #[test]
    fn test_armor_matrix_consistency() {
        // Verify armor matrix returns consistent values across multiple lookups
        use crate::weapon::armor_system::{ArmorDamageMatrix, ArmorType, DamageType};

        let matrix1 = ArmorDamageMatrix::new();
        let matrix2 = ArmorDamageMatrix::new();

        // Test all armor types
        let armor_types = vec![
            ArmorType::None,
            ArmorType::Human,
            ArmorType::Tank,
            ArmorType::Truck,
            ArmorType::Aircraft,
            ArmorType::Structure,
        ];

        // Test that two independently created matrices return identical values
        for armor_type in armor_types {
            let mult1 = matrix1.get_multiplier(armor_type, DamageType::Crush);
            let mult2 = matrix2.get_multiplier(armor_type, DamageType::Crush);
            assert_eq!(
                mult1, mult2,
                "Matrix values should be deterministic for {:?}",
                armor_type
            );
        }

        log::info!("✅ Armor matrix consistency verified");
    }

    #[test]
    fn test_projectile_detonation_reasons_integration() {
        // Verify detonation reasons integrate with physics collision system
        use crate::common::coord::Coord3D;
        use crate::weapon::projectile::{DetonationReason, Projectile};
        use std::sync::Arc;

        let weapon_template = Arc::new(crate::weapon::weapon::WeaponTemplate::new(
            "TestWeapon".to_string(),
        ));
        let trajectory = crate::weapon::ballistics::BallisticsTrajectory {
            initial_velocity: Coord3D::new(100.0, 0.0, 10.0),
            launch_angle: 0.1,
            flight_time: 1.0,
            max_height: 5.0,
            range: 100.0,
            trajectory_points: vec![],
        };

        let mut projectile = Projectile::new(
            1,
            crate::weapon::projectile::ProjectileType::Ballistic,
            weapon_template,
            2,
            Some(3),
            Coord3D::new(0.0, 0.0, 100.0),
            trajectory,
            crate::weapon::weapon::WeaponBonus::new(),
                    None,
                    INVALID_OBJECT_ID,
                    None,
        );

        // Set detonation reason
        projectile.detonation_reason = Some(DetonationReason::DirectHit);
        assert_eq!(
            projectile.detonation_reason,
            Some(DetonationReason::DirectHit)
        );

        // Change detonation reason to simulate different collision scenario
        projectile.detonation_reason = Some(DetonationReason::ProximityFuse);
        assert_eq!(
            projectile.detonation_reason,
            Some(DetonationReason::ProximityFuse)
        );

        // Verify detonation reason can be cleared
        projectile.detonation_reason = None;
        assert_eq!(projectile.detonation_reason, None);

        log::info!("✅ Projectile detonation reasons integration verified");
    }

    #[test]
    fn test_frame_time_consistency_across_systems() {
        // Verify all systems use consistent frame timing
        const EXPECTED_FPS: u32 = 30;
        const EXPECTED_DELTA_TIME: f32 = 1.0 / 30.0;

        let delta_time = 1.0 / (EXPECTED_FPS as f32);
        assert!(
            (delta_time - EXPECTED_DELTA_TIME).abs() < 0.0001,
            "Frame delta time should be 1/30"
        );

        // Verify frame timing for multiple frames
        let mut total_time = 0.0;
        for frame in 0..30 {
            total_time += EXPECTED_DELTA_TIME;
            let expected_time = (frame + 1) as f32 * EXPECTED_DELTA_TIME;
            assert!(
                (total_time - expected_time).abs() < 0.0001,
                "Frame {} time should be {}",
                frame,
                expected_time
            );
        }

        // After 30 frames (1 second at 30 FPS), time should be approximately 1.0
        assert!(
            (total_time - 1.0).abs() < 0.0001,
            "30 frames should equal 1 second"
        );

        log::info!("✅ Frame time consistency verified across all systems");
    }

    #[test]
    fn test_guided_projectile_physics_integration() {
        // Verify guided projectiles integrate ballistics tracking with physics
        use crate::common::coord::Coord3D;
        use crate::weapon::projectile::{GuidanceSystem, Projectile};
        use std::sync::Arc;

        let weapon_template = Arc::new(crate::weapon::weapon::WeaponTemplate::new(
            "GuidedMissile".to_string(),
        ));
        let trajectory = crate::weapon::ballistics::BallisticsTrajectory {
            initial_velocity: Coord3D::new(150.0, 0.0, 5.0),
            launch_angle: 0.05,
            flight_time: 2.0,
            max_height: 10.0,
            range: 150.0,
            trajectory_points: vec![],
        };

        let mut projectile = Projectile::new(
            5,
            crate::weapon::projectile::ProjectileType::Guided,
            weapon_template,
            2,
            Some(3),
            Coord3D::new(0.0, 0.0, 0.0),
            trajectory,
            crate::weapon::weapon::WeaponBonus::new(),
                    None,
                    INVALID_OBJECT_ID,
                    None,
        );

        // Set guidance system
        projectile.guidance_system = GuidanceSystem::HeatSeeking(0.8);
        assert_eq!(projectile.guidance_system, GuidanceSystem::HeatSeeking(0.8));

        // Verify guidance can be changed
        projectile.guidance_system = GuidanceSystem::RadarGuided(0.6);
        assert_eq!(projectile.guidance_system, GuidanceSystem::RadarGuided(0.6));

        // Verify guided projectile retains ballistic trajectory
        assert!(projectile.trajectory.initial_velocity[0] > 0.0);
        assert!(projectile.trajectory.flight_time > 0.0);

        log::info!("✅ Guided projectile physics integration verified");
    }
}
