    #[test]
    fn test_scripting_system() {
        let mut engine = ScriptingEngine::new();

        // Create test script
        let script_source = r#"
            function test_function() {
                return "Hello from script!";
            }
        "#;

        let script_result = engine.load_script("test_script", script_source);
        assert!(script_result.is_ok(), "Script loading should succeed");

        // Execute script function
        let context = GameStateContext::new();
        let result = engine.execute_function("test_script", "test_function", vec![], &context);
        assert!(result.is_ok(), "Script execution should succeed");

        log::info!("✅ Scripting system test passed");
    }

    #[test]
    fn test_performance_benchmark() {
        let mut fixture = GameTestFixture::new();

        // Initialize game
        {
            let mut logic = fixture.game_logic.lock().unwrap();
            logic.init().unwrap();
            logic.set_game_mode(GameMode::Skirmish);
            logic.start_game().unwrap();
        }

        // Benchmark game loop performance
        let start_time = Instant::now();
        let frames_to_simulate = 1800; // 60 seconds at 30 FPS

        let result = fixture.run_game_frames(frames_to_simulate);
        assert!(
            result.is_ok(),
            "Performance test failed: {:?}",
            result.err()
        );

        let elapsed = start_time.elapsed();
        let fps = frames_to_simulate as f64 / elapsed.as_secs_f64();

        // Should be able to simulate faster than real-time
        assert!(
            fps > 30.0,
            "Game simulation should run faster than 30 FPS, got: {:.2}",
            fps
        );

        log::info!("✅ Performance benchmark test passed - {:.2} FPS", fps);
    }

    #[test]
    fn test_memory_management() {
        // Test that we can create and destroy many objects without memory leaks
        let start_memory = get_memory_usage();

        for iteration in 0..100 {
            let mut fixture = GameTestFixture::new();

            // Initialize systems
            {
                let mut logic = fixture.game_logic.lock().unwrap();
                logic.init().unwrap();
                logic.set_game_mode(GameMode::Skirmish);
                logic.start_game().unwrap();
            }

            // Register many units for experience tracking
            for unit_id in 1000..1100 {
                fixture.experience_manager.register_unit(unit_id).unwrap();
            }

            // Create weapon templates
            with_weapon_store_mut(|store| {
                for i in 0..10 {
                    let weapon = WeaponTemplate::new(format!("TestWeapon{}", i));
                    store.add_weapon_template(weapon);
                }
            })
            .unwrap();

            // Simulate some frames
            fixture.run_game_frames(30).unwrap();

            // Clean up - this should happen automatically when fixture goes out of scope
        }

        // Force garbage collection if available
        force_garbage_collection();

        let end_memory = get_memory_usage();
        let memory_increase = end_memory - start_memory;

        // Memory increase should be reasonable (less than 100MB)
        assert!(
            memory_increase < 100 * 1024 * 1024,
            "Memory usage increased too much: {} bytes",
            memory_increase
        );

        log::info!(
            "✅ Memory management test passed - Memory increase: {} bytes",
            memory_increase
        );
    }

    #[test]
    fn test_concurrent_access() {
        use std::sync::Arc;
        use std::thread;

        // Test that multiple threads can safely access game systems
        let handles: Vec<_> = (0..4)
            .map(|thread_id| {
                thread::spawn(move || {
                    // Each thread tries to access different parts of the system
                    match thread_id {
                        0 => {
                            // Thread 0: AI operations
                            let group = {
                                let mut ai = THE_AI.write().unwrap();
                                ai.create_group()
                            };

                            for i in 0..10 {
                                let mut g = group.write().unwrap();
                                g.add(4000 + i);
                            }
                        }
                        1 => {
                            // Thread 1: Weapon operations
                            with_weapon_store_mut(|store| {
                                for i in 0..5 {
                                    let weapon =
                                        WeaponTemplate::new(format!("ConcurrentWeapon{}", i));
                                    store.add_weapon_template(weapon);
                                }
                            })
                            .unwrap();
                        }
                        2 => {
                            // Thread 2: Experience operations
                            let exp_manager = ExperienceManager::new();
                            for unit_id in 5000..5010 {
                                exp_manager.register_unit(unit_id).unwrap();

                                let award = ExperienceAward {
                                    points: 25,
                                    source: ExperienceSource::CombatKill,
                                    description: "Concurrent test".to_string(),
                                    multiplier: 1.0,
                                };
                                exp_manager.award_experience(unit_id, award).unwrap();
                            }
                        }
                        3 => {
                            // Thread 3: Economy operations
                            let mut economy = EconomyManager::new();
                            let mut resources = HashMap::new();
                            resources.insert(ResourceType::Money, 1000);
                            economy.initialize_player_economy(10, resources).unwrap();

                            for _ in 0..30 {
                                economy.update(1.0 / 30.0).unwrap();
                            }
                        }
                        _ => unreachable!(),
                    }
                })
            })
            .collect();

        // Wait for all threads to complete
        for handle in handles {
            handle.join().expect("Thread panicked");
        }

        log::info!("✅ Concurrent access test passed");
    }

    #[test]
    fn test_game_state_consistency() {
        let mut fixture = GameTestFixture::new();

        // Initialize game
        {
            let mut logic = fixture.game_logic.lock().unwrap();
            logic.init().unwrap();
            logic.set_game_mode(GameMode::Skirmish);
            logic.set_victory_condition(VictoryCondition::Annihilation);
            logic.start_game().unwrap();
        }

        // Run game for a while
        fixture.run_game_frames(300).unwrap();

        // Verify state consistency
        {
            let logic = fixture.game_logic.lock().unwrap();

            // Game should still be running
            assert_eq!(logic.get_game_state(), GameState::Running);

            // Frame counter should be advancing
            assert!(logic.get_frame() >= 300);

            // Game mode should be preserved
            assert_eq!(logic.get_game_mode(), GameMode::Skirmish);

            // Victory condition should be preserved
            assert_eq!(
                logic.get_victory_condition(),
                VictoryCondition::Annihilation
            );
        }

        // Check economy consistency
        for &player_id in &fixture.players {
            let resources = fixture
                .economy_manager
                .get_player_resources(player_id)
                .unwrap();

            // All players should have some resources
            assert!(
                resources.values().any(|&amount| amount > 0),
                "Player {} should have some resources",
                player_id
            );

            let metrics = fixture.economy_manager.get_economic_metrics(player_id);
            assert!(
                metrics.is_some(),
                "Player {} should have economic metrics",
                player_id
            );
        }

        log::info!("✅ Game state consistency test passed");
    }

