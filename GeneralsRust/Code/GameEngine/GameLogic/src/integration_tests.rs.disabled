//! Integration Testing Suite
//!
//! This module provides comprehensive integration tests for the entire GameLogic system,
//! ensuring all components work together correctly to provide a complete Command & Conquer
//! Generals Zero Hour gameplay experience.
//!
//! NOTE: This file is intentionally disabled; the tests rely on legacy APIs that no longer
//! match the current Rust port. Port/update before re-enabling.

#[cfg(all(test, feature = "ai"))]
mod tests {
    use crate::{
        ai::*, economy::*, experience::*, scripting::*, system::game_logic::*, weapon::*,
        GameLogicResult,
    };

    use std::collections::HashMap;
    use std::sync::Arc;
    use std::time::{Duration, Instant};

    /// Test fixture for full game simulation
    struct GameTestFixture {
        game_logic: Arc<std::sync::Mutex<GameLogic>>,
        economy_manager: EconomyManager,
        experience_manager: ExperienceManager,
        weapon_store: WeaponStore,
        players: Vec<u32>,
    }

    impl GameTestFixture {
        fn new() -> Self {
            let game_logic = get_game_logic();
            let mut economy_manager = EconomyManager::new();
            let experience_manager = ExperienceManager::new();
            let weapon_store = WeaponStore::new();

            // Initialize for 2 players
            let players = vec![1, 2];

            // Set up player economies
            for &player_id in &players {
                let mut starting_resources = HashMap::new();
                starting_resources.insert(ResourceType::Money, 10000);
                starting_resources.insert(ResourceType::Power, 1000);
                starting_resources.insert(ResourceType::Command, 10);

                economy_manager
                    .initialize_player_economy(player_id, starting_resources)
                    .expect("Failed to initialize player economy");
            }

            Self {
                game_logic,
                economy_manager,
                experience_manager,
                weapon_store,
                players,
            }
        }

        fn run_game_frames(&mut self, num_frames: u32) -> GameLogicResult<()> {
            for _ in 0..num_frames {
                // Update game logic
                {
                    let mut logic = self.game_logic.lock().map_err(|e| {
                        crate::GameLogicError::Threading(format!(
                            "Failed to lock game logic: {}",
                            e
                        ))
                    })?;
                    logic.update()?;
                }

                // Update economy
                self.economy_manager.update(1.0 / 30.0)?; // 30 FPS

                // Update AI
                THE_AI
                    .write()
                    .map_err(|e| {
                        crate::GameLogicError::Threading(format!("Failed to lock AI: {}", e))
                    })?
                    .update()?;
            }
            Ok(())
        }
    }

    #[test]
    fn test_full_system_initialization() {
        // Test that all systems can be initialized together
        let result = crate::initialize();
        assert!(
            result.is_ok(),
            "Failed to initialize game logic systems: {:?}",
            result.err()
        );

        // Verify AI system is functional
        let ai_group = {
            let mut ai = THE_AI.write().unwrap();
            ai.create_group()
        };
        assert!(ai_group.read().is_ok());

        // Verify weapon store is functional
        with_weapon_store(|store| {
            assert!(store.find_weapon_template("NonExistentWeapon").is_none());
        })
        .unwrap();

        log::info!("✅ Full system initialization test passed");
    }

    #[test]
    fn test_multi_player_game_simulation() {
        let mut fixture = GameTestFixture::new();

        // Initialize game
        {
            let mut logic = fixture.game_logic.lock().unwrap();
            logic.init().unwrap();
            logic.set_game_mode(GameMode::Skirmish);
            logic.start_game().unwrap();
        }

        // Simulate 30 seconds of gameplay (900 frames at 30 FPS)
        let result = fixture.run_game_frames(900);
        assert!(result.is_ok(), "Game simulation failed: {:?}", result.err());

        // Verify game state
        {
            let logic = fixture.game_logic.lock().unwrap();
            assert_eq!(logic.get_game_state(), GameState::Running);
            assert!(logic.get_frame() >= 900);
        }

        log::info!("✅ Multi-player game simulation test passed");
    }

    #[test]
    fn test_economy_integration() {
        let mut economy = EconomyManager::new();

        // Initialize player
        let mut starting_resources = HashMap::new();
        starting_resources.insert(ResourceType::Money, 5000);
        economy
            .initialize_player_economy(1, starting_resources)
            .unwrap();

        // Add economic buildings
        let supply_center = EconomicBuilding {
            object_id: 1001,
            position: [100.0, 100.0, 0.0],
            income_source: Some(IncomeSource::SupplyCenter),
            power_source: None,
            base_income_rate: 10.0,
            base_power_generation: 0.0,
            efficiency: 1.0,
            is_functional: true,
            needs_power: false,
            power_consumption: 0.0,
            upgrade_level: 0,
            health_percentage: 1.0,
        };

        economy.add_economic_building(1, supply_center).unwrap();

        // Simulate economy for 60 seconds
        for _ in 0..(60 * 30) {
            economy.update(1.0 / 30.0).unwrap();
        }

        // Verify income was generated
        let resources = economy.get_player_resources(1).unwrap();
        assert!(
            resources[&ResourceType::Money] > 5000,
            "Economy should have generated income"
        );

        // Test resource spending
        let mut costs = HashMap::new();
        costs.insert(ResourceType::Money, 1000);
        let success = economy
            .spend_resources(1, costs, "Test Purchase".to_string())
            .unwrap();
        assert!(success, "Should be able to spend resources");

        log::info!("✅ Economy integration test passed");
    }

    #[test]
    fn test_experience_and_veterancy() {
        let experience_manager = ExperienceManager::new();

        // Register test unit
        let unit_id = 2001;
        experience_manager.register_unit(unit_id).unwrap();

        // Award combat experience
        let kill_award = ExperienceAward {
            points: 50,
            source: ExperienceSource::CombatKill,
            description: "Destroyed enemy tank".to_string(),
            multiplier: 1.0,
        };

        // Award enough experience to reach veteran rank
        for _ in 0..3 {
            let promoted = experience_manager
                .award_experience(unit_id, kill_award.clone())
                .unwrap();
            if promoted {
                break;
            }
        }

        // Verify promotion
        let experience = experience_manager
            .get_unit_experience(unit_id)
            .unwrap()
            .unwrap();
        assert!(
            experience.current_rank >= VeterancyRank::Veteran,
            "Unit should be promoted to veteran"
        );

        // Test weapon bonuses integration
        let bonuses = experience_manager
            .get_veterancy_bonuses(unit_id)
            .unwrap()
            .unwrap();
        assert!(
            bonuses.damage_bonus > 1.0,
            "Veteran unit should have damage bonus"
        );

        // Test weapon bonus flags
        let weapon_flags = experience_manager.get_weapon_bonuses(unit_id).unwrap();
        assert!(
            weapon_flags.has(crate::weapon::WeaponBonusConditionType::Veteran),
            "Should have veteran weapon bonus flags"
        );

        log::info!("✅ Experience and veterancy integration test passed");
    }

    #[test]
    fn test_weapon_and_damage_system() {
        initialize_weapon_store().unwrap();

        // Create test weapon template
        let mut weapon_template = WeaponTemplate::new("TestRifle".to_string());
        weapon_template.primary_damage = 25.0;
        weapon_template.attack_range = 150.0;
        weapon_template.weapon_speed = 0.0; // Contact weapon

        let template_arc =
            with_weapon_store_mut(|store| store.add_weapon_template(weapon_template)).unwrap();

        // Create weapon instance
        let mut weapon = with_weapon_store(|store| {
            store.allocate_new_weapon(&template_arc, WeaponSlotType::Primary)
        })
        .unwrap();

        weapon.load_ammo_now(1001).unwrap();
        assert_eq!(weapon.get_status(), WeaponStatus::ReadyToFire);

        // Test weapon firing
        weapon
            .fire_weapon_at_position(1001, &[200.0, 200.0, 0.0])
            .expect("weapon should fire");

        log::info!("✅ Weapon and damage system test passed");
    }

