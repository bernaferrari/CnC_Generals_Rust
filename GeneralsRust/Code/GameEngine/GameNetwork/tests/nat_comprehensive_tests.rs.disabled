//! Comprehensive NAT traversal test suite.
//!
//! Tests all NAT traversal components for C++ compatibility.

use game_network::nat::{NatConfig, NatService, StunAttribute, StunMessage};
use game_network::nat_traversal::{
    NatBehavior, NatTraversalManager, NatType, PortAllocationPattern,
};
use game_network::security::firewall::{FirewallConfig, FirewallHelper};
use game_network::security::windows_firewall::{
    create_firewall_helper, FirewallIntegration, Protocol,
};
