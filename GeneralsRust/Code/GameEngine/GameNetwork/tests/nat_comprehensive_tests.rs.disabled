use tokio::net::UdpSocket;

// Test STUN message encoding/decoding (Part 1)
#[tokio::test]
async fn test_stun_message_encoding_decoding() {
    let msg = StunMessage::new_binding_request();
    assert_eq!(msg.message_type, 0x0001);
    assert_eq!(msg.transaction_id.len(), 12);

    // Encode
    let encoded = msg.encode();
    assert!(encoded.len() >= 20);

    // Verify header
    assert_eq!(u16::from_be_bytes([encoded[0], encoded[1]]), 0x0001);
    assert_eq!(
        u32::from_be_bytes([encoded[4], encoded[5], encoded[6], encoded[7]]),
        0x2112_A442
    );

    // Decode
    let decoded = StunMessage::decode(&encoded).unwrap();
    assert_eq!(decoded.message_type, msg.message_type);
    assert_eq!(decoded.transaction_id, msg.transaction_id);
}

#[tokio::test]
async fn test_stun_xor_mapped_address_attribute() {
    let test_addr = SocketAddr::new(IpAddr::V4(Ipv4Addr::new(192, 168, 1, 100)), 8088);

    let mut msg = StunMessage::new_binding_request();
    msg.attributes
        .push(StunAttribute::XorMappedAddress(test_addr));

    let encoded = msg.encode();
    let decoded = StunMessage::decode(&encoded).unwrap();

    let xor_addr = decoded.get_xor_mapped_address();
    assert!(xor_addr.is_some());
    assert_eq!(xor_addr.unwrap(), test_addr);
}

#[tokio::test]
async fn test_stun_software_attribute() {
    let mut msg = StunMessage::new_binding_request();
    msg.attributes
        .push(StunAttribute::Software("C&C Generals ZH".to_string()));

    let encoded = msg.encode();
    let decoded = StunMessage::decode(&encoded).unwrap();

    let has_software = decoded
        .attributes
        .iter()
        .any(|attr| matches!(attr, StunAttribute::Software(_)));
    assert!(has_software);
}

#[tokio::test]
async fn test_stun_error_code_attribute() {
    // Create a mock error response
    let data = &[
        0x01, 0x11, // BINDING_ERROR_RESPONSE
        0x00, 0x10, // Length: 16 bytes
        0x21, 0x12, 0xA4, 0x42, // Magic cookie
        0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07, 0x08, 0x09, 0x0A,
        0x0B, // Transaction ID
        0x00, 0x09, // ERROR-CODE
        0x00, 0x04, // Length: 4
        0x00, 0x00, // Reserved
        0x04, // Class: 4
        0x01, // Number: 1
    ];

    let decoded = StunMessage::decode(data).unwrap();
    assert_eq!(decoded.message_type, 0x0111);

    let has_error = decoded
        .attributes
        .iter()
        .any(|attr| matches!(attr, StunAttribute::ErrorCode { code: 401, .. }));
    assert!(has_error);
}

// Test NAT type detection (Part 5)
#[tokio::test]
async fn test_nat_type_open_internet() {
    let nat_service = Arc::new(NatService::new(NatConfig::default()));

    let manager = NatTraversalManager::new(
        0,
        Ipv4Addr::new(8, 8, 8, 8), // Public IP as local - simulates open internet
        8088,
        nat_service.clone(),
    )
    .await
    .unwrap();

    // Note: This test would require mocking STUN response
    // For now, we just verify the function doesn't panic
    let _ = manager.nat_type().await;
}

#[tokio::test]
async fn test_nat_behavior_flags() {
    let mut behavior = NatBehavior::UNKNOWN;
    assert!(!behavior.is_nat());

    behavior.insert(NatBehavior::DUMB_MANGLING);
    assert!(behavior.is_nat());
    assert!(behavior.contains(NatBehavior::DUMB_MANGLING));

    behavior.insert(NatBehavior::NETGEAR_BUG);
    assert!(behavior.is_netgear());

    behavior.insert(NatBehavior::SMART_MANGLING);
    assert!(behavior.contains(NatBehavior::SMART_MANGLING));
}

// Test symmetric NAT port prediction (Part 3)
#[tokio::test]
async fn test_port_prediction_sequential() {
    let nat_service = Arc::new(NatService::new(NatConfig::default()));
    let manager = NatTraversalManager::new(0, Ipv4Addr::new(192, 168, 1, 100), 8088, nat_service)
        .await
        .unwrap();

    let mappings = vec![
        (
            SocketAddr::new(IpAddr::V4(Ipv4Addr::new(1, 1, 1, 1)), 1000),
            9000,
        ),
        (
            SocketAddr::new(IpAddr::V4(Ipv4Addr::new(2, 2, 2, 2)), 1000),
            9001,
        ),
        (
            SocketAddr::new(IpAddr::V4(Ipv4Addr::new(3, 3, 3, 3)), 1000),
            9002,
        ),
    ];

    let predicted = manager.predict_next_ports(&mappings, 5).await;

    assert_eq!(predicted.len(), 5);
    // Should predict sequential: 9003, 9004, 9005, 9006, 9007
    assert_eq!(predicted[0], 9003);
    assert_eq!(predicted[1], 9004);
}

#[tokio::test]
async fn test_port_prediction_with_delta() {
    let nat_service = Arc::new(NatService::new(NatConfig::default()));
    let manager = NatTraversalManager::new(0, Ipv4Addr::new(192, 168, 1, 100), 8088, nat_service)
        .await
        .unwrap();

    let mappings = vec![
        (
            SocketAddr::new(IpAddr::V4(Ipv4Addr::new(1, 1, 1, 1)), 1000),
            9000,
        ),
        (
            SocketAddr::new(IpAddr::V4(Ipv4Addr::new(2, 2, 2, 2)), 1000),
            9010,
        ),
        (
            SocketAddr::new(IpAddr::V4(Ipv4Addr::new(3, 3, 3, 3)), 1000),
            9020,
        ),
    ];

    let predicted = manager.predict_next_ports(&mappings, 3).await;

    assert_eq!(predicted.len(), 3);
    // Should predict with delta of 10: 9030, 9040, 9050
    assert_eq!(predicted[0], 9030);
}

#[tokio::test]
async fn test_port_prediction_no_data() {
    let nat_service = Arc::new(NatService::new(NatConfig::default()));
    let manager = NatTraversalManager::new(0, Ipv4Addr::new(192, 168, 1, 100), 8088, nat_service)
        .await
        .unwrap();

    let mappings = vec![];
    let predicted = manager.predict_next_ports(&mappings, 3).await;

    assert_eq!(predicted.len(), 3);
    // Should return sequential from local_port
    assert_eq!(predicted[0], 8089);
    assert_eq!(predicted[1], 8090);
    assert_eq!(predicted[2], 8091);
}

