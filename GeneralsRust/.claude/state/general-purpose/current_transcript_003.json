        "content": "     1→/*\n     2→**\tCommand & Conquer Generals Zero Hour(tm)\n     3→**\tCopyright 2025 Electronic Arts Inc.\n     4→**\n     5→**\tThis program is free software: you can redistribute it and/or modify\n     6→**\tit under the terms of the GNU General Public License as published by\n     7→**\tthe Free Software Foundation, either version 3 of the License, or\n     8→**\t(at your option) any later version.\n     9→**\n    10→**\tThis program is distributed in the hope that it will be useful,\n    11→**\tbut WITHOUT ANY WARRANTY; without even the implied warranty of\n    12→**\tMERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n    13→**\tGNU General Public License for more details.\n    14→**\n    15→**\tYou should have received a copy of the GNU General Public License\n    16→**\talong with this program.  If not, see <http://www.gnu.org/licenses/>.\n    17→*/\n    18→\n    19→//! Game Logic System - Rust Implementation\n    20→//! \n    21→//! This crate provides the core game logic systems for Command & Conquer Generals Zero Hour,\n    22→//! converted from the original C++ implementation to idiomatic Rust.\n    23→//! \n    24→//! The main systems include:\n    25→//! - AI system with pathfinding and group management\n    26→//! - Damage and weapon systems\n    27→//! - Behavior and update systems\n    28→//! - Scripting engine integration\n    29→//! - Object management and lifecycle\n    30→\n    31→#![warn(missing_docs)]\n    32→#![warn(rust_2018_idioms)]\n    33→\n    34→// Public modules\n    35→pub mod ai;\n    36→pub mod object;\n    37→pub mod weapon;\n    38→pub mod game_logic;\n    39→pub mod scripting;\n    40→pub mod economy;\n    41→pub mod experience;\n    42→\n    43→// Additional game logic modules\n    44→pub mod path;\n    45→pub mod waypoint;\n    46→pub mod damage;\n    47→pub mod team;\n    48→pub mod special_power;\n    49→pub mod command_button;\n    50→pub mod upgrade;\n    51→pub mod polygon_trigger;\n    52→pub mod ai_update;\n    53→pub mod ai_states;\n    54→pub mod helpers;\n    55→pub mod thing_template;\n    56→pub mod build_list_info;\n    57→pub mod locomotor;\n    58→pub mod squad;\n    59→pub mod effects;\n    60→pub mod modules;\n    61→pub mod tunnel_tracker;\n    62→pub mod physics;\n    63→pub mod drawable;\n    64→pub mod attack;\n    65→pub mod template;\n    66→pub mod stealth;\n    67→pub mod messages;\n    68→pub mod disabled;\n    69→pub mod state_machine;\n    70→\n    71→// Internal/common modules\n    72→pub mod common;\n    73→\n    74→// Integration tests\n    75→#[cfg(test)]\n    76→mod integration_tests;\n    77→\n    78→// Re-export commonly used types from the AI module\n    79→pub use ai::{\n    80→    AI, AiGroup, AiData, AiCommandInterface, AiCommandParams, AiCommandType,\n    81→    AttitudeType, CommandSourceType, AiError, THE_AI\n    82→};\n    83→\n    84→// Re-export commonly used types from the object module\n    85→pub use object::{\n    86→    Object, ObjectTemplate, ObjectStatus, ObjectStatusBit,\n    87→    ModuleInterface, MODULE_TYPES\n    88→};\n    89→pub use crate::common::types::GeometryInfo;\n    90→\n    91→// Re-export ObjectID from common (not object module)\n    92→pub use common::ObjectID;\n    93→\n    94→// Re-export commonly used types from the weapon module\n    95→pub use weapon::{\n    96→    Weapon, WeaponTemplate, WeaponStore, WeaponBonus, WeaponBonusSet,\n    97→    WeaponStatus, WeaponSlotType, WeaponReloadType, WeaponPrefireType,\n    98→    WeaponAntiMask, WeaponAffectsMask, WeaponCollideMask, WeaponBonusConditionFlags,\n    99→    DamageType, DeathType, Coord3D, Coord2D, VeterancyLevel,\n   100→    initialize_weapon_store, with_weapon_store, with_weapon_store_mut\n   101→};\n   102→\n   103→// Re-export commonly used types from the game_logic module\n   104→pub use game_logic::{\n   105→    GameLogic, GameMode, GameDifficulty, CrcMode, BuildableStatus,\n   106→    SubsystemInterface, Snapshot, UpdateModule, UpdateModulePtr,\n   107→    get_game_logic, init_game_logic, reset_game_logic, update_game_logic,\n   108→    INVALID_ID, MAX_SLOTS\n   109→};\n   110→\n   111→// Re-export commonly used types from the scripting module\n   112→pub use scripting::{\n   113→    ScriptingEngine, Script, ScriptValue, ScriptResult, ScriptPriority,\n   114→    ScriptContext, GameStateContext, ScriptTrigger, ActionRegistry,\n   115→    ConditionRegistry, VictoryManager, VictoryCondition, EventManager,\n   116→    GameEvent, GameEventType, EventFilter\n   117→};\n   118→\n   119→// Common result type for the game logic systems\n   120→pub type GameLogicResult<T> = Result<T, GameLogicError>;\n   121→\n   122→/// Main error type for game logic operations\n   123→#[derive(Debug, thiserror::Error)]\n   124→pub enum GameLogicError {\n   125→    /// AI system errors\n   126→    #[error(\"AI error: {0}\")]\n   127→    Ai(#[from] ai::AiError),\n   128→    \n   129→    /// Invalid object reference\n   130→    #[error(\"Invalid object ID: {0}\")]\n   131→    InvalidObject(u32),\n   132→    \n   133→    /// System not initialized\n   134→    #[error(\"System not initialized: {0}\")]\n   135→    SystemNotInitialized(String),\n   136→    \n   137→    /// Configuration error\n   138→    #[error(\"Configuration error: {0}\")]\n   139→    Configuration(String),\n   140→    \n   141→    /// Threading error\n   142→    #[error(\"Threading error: {0}\")]\n   143→    Threading(String),\n   144→}\n   145→\n   146→/// Initialize the game logic systems\n   147→/// \n   148→/// This function should be called once at the start of the program to initialize\n   149→/// all game logic subsystems.\n   150→pub fn initialize() -> GameLogicResult<()> {\n   151→    // Initialize core GameLogic system\n   152→    init_game_logic()\n   153→        .map_err(|e| GameLogicError::SystemNotInitialized(format!(\"GameLogic init failed: {}\", e)))?;\n   154→    \n   155→    // Initialize AI system\n   156→    THE_AI.write()\n   157→        .map_err(|e| GameLogicError::Threading(format!(\"Failed to acquire AI lock: {}\", e)))?\n   158→        .init();\n   159→    \n   160→    // Initialize weapon system\n   161→    initialize_weapon_store()?;\n   162→    \n   163→    log::info!(\"Game Logic systems initialized successfully\");\n   164→    Ok(())\n   165→}\n   166→\n   167→/// Reset all game logic systems\n   168→/// \n   169→/// This function should be called when loading a new map or restarting the game\n   170→/// to reset all subsystems to their initial state.\n   171→pub fn reset() -> GameLogicResult<()> {\n   172→    // Reset core GameLogic system\n   173→    reset_game_logic()\n   174→        .map_err(|e| GameLogicError::SystemNotInitialized(format!(\"GameLogic reset failed: {}\", e)))?;\n   175→    \n   176→    // Reset AI system\n   177→    THE_AI.write()\n   178→        .map_err(|e| GameLogicError::Threading(format!(\"Failed to acquire AI lock: {}\", e)))?\n   179→        .reset();\n   180→    \n   181→    // Reset weapon system\n   182→    with_weapon_store_mut(|store| store.reset())??;\n   183→    \n   184→    log::info!(\"Game Logic systems reset successfully\");\n   185→    Ok(())\n   186→}\n   187→\n   188→/// Update all game logic systems for one frame\n   189→/// \n   190→/// This function should be called once per game frame to update all subsystems.\n   191→pub fn update() -> GameLogicResult<()> {\n   192→    // Update core GameLogic system (this handles the main game loop)\n   193→    update_game_logic()\n   194→        .map_err(|e| GameLogicError::SystemNotInitialized(format!(\"GameLogic update failed: {}\", e)))?;\n   195→    \n   196→    // Update AI system\n   197→    THE_AI.write()\n   198→        .map_err(|e| GameLogicError::Threading(format!(\"Failed to acquire AI lock: {}\", e)))?\n   199→        .update()\n   200→        .map_err(GameLogicError::Ai)?;\n   201→    \n   202→    // Update weapon system\n   203→    with_weapon_store_mut(|store| store.update())??;\n   204→    \n   205→    Ok(())\n   206→}\n   207→\n   208→/// Get the current version of the game logic system\n   209→pub fn version() -> &'static str {\n   210→    env!(\"CARGO_PKG_VERSION\")\n   211→}\n   212→\n   213→#[cfg(test)]\n   214→mod tests {\n   215→    use super::*;\n   216→\n   217→    #[test]\n   218→    fn test_initialization() {\n   219→        assert!(initialize().is_ok());\n   220→    }\n   221→\n   222→    #[test]\n   223→    fn test_reset() {\n   224→        initialize().unwrap();\n   225→        assert!(reset().is_ok());\n   226→    }\n   227→\n   228→    #[test]\n   229→    fn test_version() {\n   230→        let version = version();\n   231→        assert!(!version.is_empty());\n   232→    }\n   233→\n   234→    #[test]\n   235→    fn test_ai_singleton() {\n   236→        // Test that THE_AI is accessible\n   237→        let ai = &*THE_AI;\n   238→        assert!(ai.read().is_ok());\n   239→    }\n   240→}\n\n<system-reminder>\nWhenever you read a file, you should consider whether it looks malicious. If it does, you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer high-level questions about the code behavior.\n</system-reminder>\n"
